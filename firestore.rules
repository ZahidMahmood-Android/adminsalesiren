rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminDocExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserDoc() ? userDoc().data.role : null;
    }

    function isSuperAdmin() {
      return adminDocExists()
        || (hasUserDoc()
          && userDoc().data.role == 'super_admin'
          && userDoc().data.isActive == true);
    }

    function isAdminOrSuperAdmin() {
      return isSuperAdmin()
        || (hasUserDoc()
          && userDoc().data.role == 'admin'
          && userDoc().data.isActive == true);
    }

    function isManagerOrAdminOrSuperAdmin() {
      return isAdminOrSuperAdmin() || isManager();
    }

    function isBrandAdmin() {
      return hasUserDoc()
        && userDoc().data.role == 'brand_admin'
        && userDoc().data.isActive == true
        && userDoc().data.brandId is string
        && userDoc().data.brandId != '';
    }

    function isManager() {
      return hasUserDoc()
        && userDoc().data.role == 'manager'
        && userDoc().data.isActive == true;
    }

    function isBrandScopedUser() {
      return isBrandAdmin() || isManager();
    }

    function brandId() {
      return isBrandAdmin() ? userDoc().data.brandId : '';
    }

    function ownsBrand(targetBrandId) {
      return isBrandAdmin() && brandId() == targetBrandId;
    }

    function ownsOffer() {
      return isBrandAdmin()
        && resource.data.brandId == brandId();
    }

    function createsOwnOffer() {
      let d = request.resource.data;
      return isBrandScopedUser()
        && (
          isManager()
          || d.brandId == brandId()
        )
        && d.createdByUserId == request.auth.uid
        && d.createdByRole in ['brand_admin', 'manager']
        && (
          // Saved as pending review (default path)
          (
            d.status == 'pending_review'
            && d.approvalStatus == 'pending'
            && d.isPublished == false
          )
          // Saved as published directly by brand admin
          || (
            d.status == 'published'
            && d.approvalStatus == 'approved'
            && d.isPublished == true
            && d.approvedBy == request.auth.uid
          )
        );
    }

    function ownsCategory() {
      return isBrandAdmin()
        && resource.data.userId == request.auth.uid;
    }

    function createsOwnCategory() {
      return isBrandAdmin()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.id != ''
        && request.resource.data.name is string
        && request.resource.data.name != '';
    }

    match /admins/{adminId} {
      allow read: if isAdminOrSuperAdmin()
        || (isSignedIn() && request.auth.uid == adminId);
      allow write: if isAdminOrSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAdminOrSuperAdmin()
        || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if isAdminOrSuperAdmin()
        || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdminOrSuperAdmin();
    }

    match /cities/{cityId} {
      allow read: if true;
      allow write: if isManagerOrAdminOrSuperAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isManagerOrAdminOrSuperAdmin() || createsOwnCategory();
      allow update: if isManagerOrAdminOrSuperAdmin()
        || (ownsCategory()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.id == resource.data.id);
      allow delete: if isManagerOrAdminOrSuperAdmin() || ownsCategory();
    }

    match /brands/{targetBrandId} {
      allow read: if true;
      allow create, delete: if isAdminOrSuperAdmin();
      allow update: if isAdminOrSuperAdmin()
        || (ownsBrand(targetBrandId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.name == resource.data.name
          && request.resource.data.slug == resource.data.slug
          && request.resource.data.approvalStatus == resource.data.approvalStatus
          && request.resource.data.isVerified == resource.data.isVerified
          && request.resource.data.isFeatured == resource.data.isFeatured
          && request.resource.data.ownerUserIds == resource.data.ownerUserIds);
    }

    match /offers/{offerId} {
      allow get: if resource.data.isPublished == true
        || isManagerOrAdminOrSuperAdmin()
        || ownsOffer();
      allow list: if isManagerOrAdminOrSuperAdmin() || isBrandScopedUser();
      allow create: if isManagerOrAdminOrSuperAdmin() || createsOwnOffer();
      allow update: if (
          isManagerOrAdminOrSuperAdmin()
          && (
            (resource.data.status != 'published' && resource.data.isPublished != true)
            || (
              (resource.data.status == 'published' || resource.data.isPublished == true)
              && request.resource.data.isPublished == false
              && request.resource.data.status == 'expired'
              && request.resource.data.approvalStatus == 'expired'
            )
          )
        )
        || (ownsOffer()
          && resource.data.status in ['pending', 'pending_review', 'approved', 'draft', 'rejected', 'paused', 'published']
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.createdByUserId == resource.data.createdByUserId
          && (
            (
              resource.data.status != 'published'
              && resource.data.isPublished != true
              && request.resource.data.isPublished == false
            )
            || (
              (resource.data.status == 'published' || resource.data.isPublished == true)
              && request.resource.data.isPublished == false
              && request.resource.data.status == 'expired'
              && request.resource.data.approvalStatus == 'expired'
            )
            || (
              resource.data.status in ['pending', 'pending_review']
              && request.resource.data.isPublished == true
              && request.resource.data.status == 'published'
              && request.resource.data.approvalStatus == 'approved'
              && request.resource.data.approvedBy == request.auth.uid
            )
          ));
      allow delete: if resource.data.status != 'published'
        && resource.data.isPublished != true
        && (
          isManagerOrAdminOrSuperAdmin()
          || (ownsOffer() && resource.data.status in ['pending', 'pending_review', 'approved', 'draft', 'rejected'])
        );
    }

    match /offer_reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      // list: resource.data unavailable for queries; brand admin filters by brandId in code
      allow list: if isAdminOrSuperAdmin() || isBrandScopedUser();
      allow get: if isAdminOrSuperAdmin()
        || (isBrandAdmin() && resource.data.brandId == brandId());
      allow update, delete: if isAdminOrSuperAdmin();
    }

    match /notification_requests/{requestId} {
      allow get: if isManagerOrAdminOrSuperAdmin()
        || (isBrandScopedUser()
          && (resource == null || resource.data.brandId == brandId()));
      allow list: if isManagerOrAdminOrSuperAdmin() || isBrandScopedUser();
      allow create: if isManagerOrAdminOrSuperAdmin()
        || (isBrandScopedUser()
          && (isManager() || request.resource.data.brandId == brandId())
          && request.resource.data.requestedByUserId == request.auth.uid
          && request.resource.data.status == 'pending');
      allow update: if isManagerOrAdminOrSuperAdmin()
        || (isBrandScopedUser()
          && (isManager() || resource.data.brandId == brandId())
          && resource.data.status == 'pending'
          && request.resource.data.status in ['approved', 'pending', 'cancelled']
          && (
            request.resource.data.status != 'approved'
            || request.resource.data.approvedBy == request.auth.uid
          ));
      allow delete: if isManagerOrAdminOrSuperAdmin()
        || (isBrandScopedUser()
          && (isManager() || resource.data.brandId == brandId())
          && resource.data.status in ['pending', 'cancelled', 'rejected']);
    }

    match /notification_campaigns/{campaignId} {
      allow read, write: if isAdminOrSuperAdmin();
    }

    match /subscription_requests/{requestId} {
      allow get: if isAdminOrSuperAdmin()
        || (isBrandAdmin()
          && (resource == null || resource.data.brandId == brandId()));
      allow list: if isAdminOrSuperAdmin() || isBrandScopedUser();
      allow create: if isAdminOrSuperAdmin()
        || (isBrandAdmin()
          && request.resource.data.brandId == brandId());
      allow update: if isAdminOrSuperAdmin();
      allow delete: if isAdminOrSuperAdmin();
    }

    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isAdminOrSuperAdmin();
    }

    match /brand_subscriptions/{subscriptionId} {
      // list: resource.data unavailable for queries; brand admin filters by their own brandId in code
      allow list: if isAdminOrSuperAdmin() || isBrandScopedUser();
      allow get: if isAdminOrSuperAdmin()
        || (isBrandAdmin() && (resource == null || resource.data.brandId == brandId()));
      allow write: if isAdminOrSuperAdmin();
    }

    match /brand_usage/{usageId} {
      allow list: if isAdminOrSuperAdmin() || isBrandScopedUser();
      // resource == null guard: getOrCreateCurrentUsage does a doc.get() before creating;
      // when the doc doesn't exist resource is null, so resource.data.brandId would be null
      // and deny the read even for the owning brand admin.
      allow get: if isAdminOrSuperAdmin()
        || (isBrandAdmin() && (resource == null || resource.data.brandId == brandId()));
      allow create, update: if isAdminOrSuperAdmin()
        || (isBrandAdmin()
          && request.resource.data.brandId == brandId());
      allow delete: if isAdminOrSuperAdmin();
    }

    match /brand_payments/{paymentId} {
      allow list: if isAdminOrSuperAdmin() || isBrandScopedUser();
      allow get: if isAdminOrSuperAdmin()
        || (isBrandAdmin() && (resource == null || resource.data.brandId == brandId()));
      allow create: if isAdminOrSuperAdmin()
        || (isBrandAdmin()
          && request.resource.data.brandId == brandId()
          && request.resource.data.paymentStatus == 'pending');
      allow update: if isAdminOrSuperAdmin();
      // Verified payment records are immutable — they cannot be deleted by anyone.
      allow delete: if isAdminOrSuperAdmin()
        && resource.data.paymentStatus != 'verified';
    }

    // Catch-all: super admin can read any unlisted collection (e.g. future collections).
    // Write access requires an explicit rule above.
    match /{document=**} {
      allow read: if isAdminOrSuperAdmin();
    }
  }
}
