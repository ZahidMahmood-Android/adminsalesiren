// Canonical Firestore rules for Sale Siren (admin panel + mobile app).
// After any edit here, copy this file to apps/mobileapp/firestore.rules
// (keep the mobileapp line-1 sync comment). Both files must stay identical.
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(docId) {
      return isSignedIn() && request.auth.uid == docId;
    }

    function adminDocExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function adminReferenceRole() {
      return adminDocExists()
        ? get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role
        : null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRoleList() {
      return hasUserDoc() && userDoc().data.roles is list && userDoc().data.roles.size() > 0
        ? userDoc().data.roles
        : (hasUserDoc()
          && userDoc().data.role is string
          && userDoc().data.role != ''
            ? [userDoc().data.role]
            : []);
    }

    function hasUserRole(r) {
      return r in userRoleList()
        || (hasUserDoc() && userDoc().data.role == r);
    }

    function role() {
      return hasUserDoc() ? userDoc().data.role : null;
    }

    function hasOwnerRole() {
      return hasUserRole('owner');
    }

    function isOwner() {
      return (hasUserDoc()
          && hasOwnerRole()
          && userDoc().data.isActive == true)
        || (adminDocExists() && adminReferenceRole() == 'owner');
    }

    function isAdminOrOwner() {
      return isOwner()
        || (hasUserDoc()
          && hasUserRole('admin')
          && userDoc().data.isActive == true);
    }

    function isManagerOrAdminOrOwner() {
      return isAdminOrOwner() || isManager();
    }

    function isBrandAdmin() {
      return hasUserDoc()
        && hasUserRole('brand_admin')
        && userDoc().data.isActive == true
        && userDoc().data.brandId is string
        && userDoc().data.brandId != '';
    }

    function isManager() {
      return hasUserDoc()
        && hasUserRole('manager')
        && userDoc().data.isActive == true;
    }

    function isMobileUser() {
      return hasUserDoc()
        && hasUserRole('mobile_user')
        && userDoc().data.isActive == true;
    }

    function isBrandScopedUser() {
      return isBrandAdmin() || isManager();
    }

    function brandId() {
      return isBrandAdmin() ? userDoc().data.brandId : '';
    }

    function userFeatureIds() {
      return hasUserDoc() && userDoc().data.featureIds is list
        ? userDoc().data.featureIds
        : [];
    }

    function hasAssignedFeature(featureId) {
      return featureId in userFeatureIds();
    }

    function canManageBugReports() {
      return isOwner() || hasAssignedFeature('admin_bug_reports');
    }

    function ownsBrand(targetBrandId) {
      return isBrandAdmin() && brandId() == targetBrandId;
    }

    function ownsOffer() {
      return isBrandAdmin()
        && resource.data.brandId == brandId();
    }

    function offerCreatedByUserId(data) {
      return data.get('createdByUserId', '') != ''
        ? data.get('createdByUserId', '')
        : data.get('createdBy', '');
    }

    function offerStatus(data) {
      return data.get('status', '') != ''
        ? data.get('status', '')
        : (data.get('isPublished', false) == true ? 'published' : 'draft');
    }

    function isPublishedLikeStatus(status) {
      return status == 'published' || status == 'approved';
    }

    function preservesCreatedByUserId() {
      return offerCreatedByUserId(request.resource.data) != ''
        && offerCreatedByUserId(request.resource.data)
            == offerCreatedByUserId(resource.data);
    }

    function isPublishedOffer() {
      return resource.data.isPublished == true;
    }

    function canAdminPanelUpdateOffer() {
      let d = request.resource.data;
      return isSignedIn()
        && d.brandId == resource.data.brandId
        && (
          isManagerOrAdminOrOwner()
          || (isBrandAdmin() && resource.data.brandId == brandId())
        );
    }

    function preservesPublishedOfferState() {
      return request.resource.data.brandId == resource.data.brandId
        && preservesCreatedByUserId()
        && request.resource.data.isPublished == true
        && isPublishedLikeStatus(request.resource.data.status)
        && request.resource.data.approvalStatus == 'approved';
    }

    function canEditPublishedOfferContent() {
      return isPublishedOffer() && preservesPublishedOfferState();
    }

    function canExpirePublishedOffer() {
      return isPublishedOffer()
        && request.resource.data.isPublished == false
        && request.resource.data.status == 'expired'
        && request.resource.data.approvalStatus == 'expired';
    }

    function createsOwnOffer() {
      let d = request.resource.data;
      let pendingPath =
        d.status == 'pending_review'
        && d.approvalStatus == 'pending'
        && d.isPublished == false;
      let publishedPath =
        d.status == 'published'
        && d.approvalStatus == 'approved'
        && d.isPublished == true
        && d.approvedBy == request.auth.uid;
      return isBrandScopedUser()
        && (
          isManager()
          || d.brandId == brandId()
        )
        && d.createdByUserId == request.auth.uid
        && d.createdByRole in ['brand_admin', 'manager']
        && (
          (isManager() && pendingPath)
          || (isBrandAdmin() && (pendingPath || publishedPath))
        );
    }

    function ownsCategory() {
      return isBrandAdmin()
        && resource.data.userId == request.auth.uid;
    }

    function createsOwnCategory() {
      return isBrandAdmin()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.id != ''
        && request.resource.data.name is string
        && request.resource.data.name != '';
    }

    function targetIsOwner() {
      return resource != null
        && (
          resource.data.role == 'owner'
          || (resource.data.roles is list && 'owner' in resource.data.roles)
        );
    }

    function requestIsMobileUserOnly() {
      return dataIsMobileUserOnly(request.resource.data);
    }

    function dataIsMobileUserOnly(data) {
      return !existingHasPrivilegedRole(data)
        && (
          data.role == 'mobile_user'
          || (data.roles is list && 'mobile_user' in data.roles)
          || (!('role' in data) && !('roles' in data))
        );
    }

    function existingHasPrivilegedRole(data) {
      return data.get('role', '') in ['owner', 'admin', 'brand_admin', 'manager']
        || (data.roles is list && (
          'owner' in data.roles
          || 'admin' in data.roles
          || 'brand_admin' in data.roles
          || 'manager' in data.roles
        ));
    }

    // Mobile app signup/sign-in: user creates or updates their own mobile profile.
    function mobileOwnUserWrite(userId) {
      let d = request.resource.data;
      return isSignedIn()
        && request.auth.uid == userId
        && dataIsMobileUserOnly(d)
        && d.get('brandId', '') == ''
        && d.get('isActive', true) == true
        && d.get('isAdminEnabled', false) == false;
    }

    // Mobile app: merge updates for notification/profile prefs on own user doc.
    function mobileOwnProfilePatch(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && !existingHasPrivilegedRole(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'fullName',
          'phoneNumber',
          'photoUrl',
          'notificationEnabled',
          'fcmTokens',
          'updatedAt',
          'selectedCategories',
          'favoriteBrands',
        ]);
    }

    // Privileged admin users may update their own contact info and preferences only.
    function privilegedOwnProfileWrite(userId) {
      let d = request.resource.data;
      return isSignedIn()
        && request.auth.uid == userId
        && existingHasPrivilegedRole(resource.data)
        && d.get('email', '') == resource.data.get('email', '')
        && d.get('role', '') == resource.data.get('role', '')
        && d.get('brandId', '') == resource.data.get('brandId', '')
        && d.get('isActive', true) == resource.data.get('isActive', true)
        && d.get('isAdminEnabled', false) == resource.data.get('isAdminEnabled', false)
        && d.get('isMobileAppEnabled', true) == resource.data.get('isMobileAppEnabled', true)
        && d.get('mustChangePassword', false) == resource.data.get('mustChangePassword', false)
        && d.get('roles', []) == resource.data.get('roles', []);
    }

    match /admins/{adminId} {
      // Reference only: { id, role } for owner access checks and storage rules.
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow get: if isAdminOrOwner() || isManager();
      allow list: if isAdminOrOwner() || isManager();
      allow create, update: if isOwner()
        && request.resource.data.id == adminId
        && request.resource.data.role == 'owner';
      allow delete: if isOwner();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow get: if isOwner()
        || (isAdminOrOwner() && !isManager())
        || (isManager() && !targetIsOwner());
      allow list: if isOwner()
        || isManager()
        || (isAdminOrOwner() && !isManager());
      allow create: if isOwner() || mobileOwnUserWrite(userId);
      allow update: if isOwner()
        || privilegedOwnProfileWrite(userId)
        || mobileOwnProfilePatch(userId)
        || (mobileOwnUserWrite(userId) && !existingHasPrivilegedRole(resource.data));
      allow delete: if isOwner();

      // Mobile app: each signed-in user owns their saved offers.
      match /saved_offers/{offerId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Mobile app: each signed-in user owns their saved brands.
      match /saved_brands/{brandId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Mobile app: each signed-in user owns their selected categories.
      match /selected_categories/{categoryId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      // Mobile app: in-app notification history for the signed-in user.
      match /alerts/{alertId} {
        allow read, update: if isSignedIn() && request.auth.uid == userId;
        allow create: if false;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /cities/{cityId} {
      allow read: if true;
      allow write: if isManagerOrAdminOrOwner();
    }

    match /roles/{roleId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /app_features/{featureId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /app_settings/{settingId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isManagerOrAdminOrOwner() || createsOwnCategory();
      allow update: if isManagerOrAdminOrOwner()
        || (ownsCategory()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.id == resource.data.id);
      allow delete: if isManagerOrAdminOrOwner() || ownsCategory();
    }

    match /brands/{targetBrandId} {
      allow read: if true;
      allow create: if isAdminOrOwner() || isManager();
      allow delete: if isAdminOrOwner();
      allow update: if isAdminOrOwner() || isManager()
        || (ownsBrand(targetBrandId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.name == resource.data.name
          && request.resource.data.slug == resource.data.slug
          && request.resource.data.approvalStatus == resource.data.approvalStatus
          && request.resource.data.isVerified == resource.data.isVerified
          && request.resource.data.isFeatured == resource.data.isFeatured
          && request.resource.data.ownerUserIds == resource.data.ownerUserIds);
    }

    match /offers/{offerId} {
      // Public mobile feed: anyone can read offers that are published, verified,
      // and not expired. Unpublished/unverified/expired offers stay hidden.
      allow get: if (resource.data.isPublished == true
          && resource.data.isVerified == true
          && resource.data.status != 'expired')
        || isManagerOrAdminOrOwner()
        || ownsOffer();
      allow list: if isManagerOrAdminOrOwner()
        || isBrandScopedUser()
        || (resource.data.isPublished == true
          && resource.data.isVerified == true
          && resource.data.status != 'expired');
      allow create: if isManagerOrAdminOrOwner() || createsOwnOffer();
      allow update: if canAdminPanelUpdateOffer()
        || (
          isMobileUser()
          && resource.data.isPublished == true
          && request.resource.data.isPublished == true
          && request.resource.data.saveCount is int
          && request.resource.data.shareCount is int
          && request.resource.data.saveCount >= resource.data.saveCount
          && request.resource.data.shareCount >= resource.data.shareCount
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['saveCount', 'shareCount', 'updatedAt'])
        );
      allow delete: if isManagerOrAdminOrOwner()
        || (
          resource.data.status != 'published'
          && resource.data.isPublished != true
          && ownsOffer()
          && resource.data.status in ['pending', 'pending_review', 'approved', 'draft', 'rejected', 'expired']
        );
    }

    match /offer_reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      // list: resource.data unavailable for queries; brand admin filters by brandId in code
      allow list: if isAdminOrOwner() || isBrandScopedUser();
      allow get: if isAdminOrOwner()
        || (isBrandAdmin() && resource.data.brandId == brandId());
      allow update, delete: if isAdminOrOwner();
    }

    match /bug_reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.source in ['mobile', 'admin']
        && request.resource.data.status == 'new'
        && request.resource.data.keys().hasAll([
          'userId', 'source', 'category', 'title', 'details', 'status', 'createdAt'
        ]);
      allow list, get, update, delete: if canManageBugReports();
    }

    match /notification_requests/{requestId} {
      allow get: if isManagerOrAdminOrOwner()
        || (isBrandScopedUser()
          && (resource == null || resource.data.brandId == brandId()));
      allow list: if isManagerOrAdminOrOwner() || isBrandScopedUser();
      allow create: if isManagerOrAdminOrOwner()
        || (isBrandScopedUser()
          && (isManager() || request.resource.data.brandId == brandId())
          && request.resource.data.requestedByUserId == request.auth.uid
          && request.resource.data.status == 'pending');
      allow update: if isManagerOrAdminOrOwner()
        || (isBrandScopedUser()
          && (isManager() || resource.data.brandId == brandId())
          && resource.data.status in ['pending', 'sent']
          && (
            (resource.data.status == 'sent'
              && request.resource.data.status == resource.data.status)
            || (resource.data.status == 'pending'
              && request.resource.data.status in ['approved', 'pending', 'cancelled'])
          )
          && (
            request.resource.data.status != 'approved'
            || request.resource.data.approvedBy == request.auth.uid
          ));
      allow delete: if isManagerOrAdminOrOwner()
        || (isBrandScopedUser()
          && (isManager() || resource.data.brandId == brandId())
          && resource.data.status in ['pending', 'cancelled', 'rejected']);
    }

    match /offer_push_jobs/{jobId} {
      allow read: if isManagerOrAdminOrOwner();
      allow create, update: if isManagerOrAdminOrOwner() || isBrandScopedUser();
      allow delete: if isManagerOrAdminOrOwner();
    }

    match /registration_email_verification_jobs/{jobId} {
      allow read: if isOwner()
        && resource.data.requestedByUid == request.auth.uid;
      allow create: if isOwner()
        && request.resource.data.requestedByUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.action in ['start', 'check_status', 'cancel']
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3;
      allow update, delete: if false;
    }

    match /notification_campaigns/{campaignId} {
      allow read, write: if isAdminOrOwner();
    }

    match /subscription_requests/{requestId} {
      allow get: if isAdminOrOwner()
        || (isBrandAdmin()
          && (resource == null || resource.data.brandId == brandId()));
      allow list: if isAdminOrOwner() || isBrandScopedUser();
      allow create: if isAdminOrOwner()
        || (isBrandAdmin()
          && request.resource.data.brandId == brandId());
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isAdminOrOwner();
    }

    match /brand_subscriptions/{subscriptionId} {
      // list: resource.data unavailable for queries; brand admin filters by their own brandId in code
      allow list: if isAdminOrOwner() || isBrandScopedUser();
      allow get: if isAdminOrOwner()
        || (isBrandAdmin() && (resource == null || resource.data.brandId == brandId()));
      allow write: if isAdminOrOwner();
    }

    match /brand_usage/{usageId} {
      allow list: if isAdminOrOwner() || isBrandScopedUser();
      // resource == null guard: getOrCreateCurrentUsage does a doc.get() before creating;
      // when the doc doesn't exist resource is null, so resource.data.brandId would be null
      // and deny the read even for the owning brand admin.
      allow get: if isAdminOrOwner()
        || (isBrandAdmin() && (resource == null || resource.data.brandId == brandId()));
      allow create, update: if isAdminOrOwner()
        || (isBrandAdmin()
          && request.resource.data.brandId == brandId());
      allow delete: if isAdminOrOwner();
    }

    match /brand_payments/{paymentId} {
      allow list: if isAdminOrOwner() || isBrandScopedUser();
      allow get: if isAdminOrOwner()
        || (isBrandAdmin() && (resource == null || resource.data.brandId == brandId()));
      allow create: if isAdminOrOwner()
        || (isBrandAdmin()
          && request.resource.data.brandId == brandId()
          && request.resource.data.paymentStatus == 'pending');
      allow update: if isAdminOrOwner();
      // Verified payment records are immutable — they cannot be deleted by anyone.
      allow delete: if isAdminOrOwner()
        && resource.data.paymentStatus != 'verified';
    }

    // Catch-all: owner can read any unlisted collection (e.g. future collections).
    // Write access requires an explicit rule above.
    match /{document=**} {
      allow read: if isAdminOrOwner();
    }
  }
}
